        }

        function truncateFilename(name, maxLength = 50) {
            if (name.length <= maxLength) return name;
            const extIndex = name.lastIndexOf('.');
            const ext = extIndex !== -1 ? name.substring(extIndex) : '';
            const baseName = extIndex !== -1 ? name.substring(0, extIndex) : name;
            
            if (baseName.length <= 25) return name; 

            const start = baseName.substring(0, maxLength - 15);
            const end = baseName.substring(baseName.length - 8);
            return `${start}......${end}${ext}`;
        }

        function formatBytes(bytes, decimals = 1) {
            if (bytes === 0) return '0 Bytes';
            const k = 1024;
            const dm = decimals < 0 ? 0 : decimals;
            const sizes = ['Bytes', 'KB', 'MB', 'GB', 'TB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
        }

        function togglePassword(id) {
            const input = document.getElementById(id);
            if (input.type === 'password') {
                input.type = 'text';
            } else {
                input.type = 'password';
            }
        }

        async function handleFiles(files) {
            if (currentTool === 'split') {
                if (typeof PDFLib === 'undefined') {
                    showToast('Lỗi', 'Thư viện xử lý PDF chưa tải xong. Vui lòng thử lại sau giây lát.');
                    return;
                }
                selectedFiles = []; // Only one file for split
            } else if (currentTool === 'compress') {
                if (typeof PDFLib === 'undefined') {
                    showToast('Lỗi', 'Thư viện xử lý PDF chưa tải xong. Vui lòng thử lại sau giây lát.');
                    return;
                }
                // Multiple files allowed for compress
            }
            for (let i = 0; i < files.length; i++) {
                const file = files[i];
                
                // Check page count for split tool
                if (currentTool === 'split') {
                    try {
                        const { PDFDocument } = PDFLib;
                        const arrayBuffer = await file.arrayBuffer();
                        const pdfDoc = await PDFDocument.load(arrayBuffer);
                        const pageCount = pdfDoc.getPageCount();
                        if (pageCount <= 1) {
                            showToast('Tệp này chỉ có 1 trang, không thể tách.', file.name);
                            continue;
                        }
                    } catch (e) {
                        console.error('Error loading PDF:', e);
                        showToast('Không thể đọc tệp PDF này.', file.name);
                        continue;
                    }
                }

                const fileObj = {
                    id: Math.random().toString(36).substr(2, 9),
                    file: file,
                    name: file.name,
                    size: file.size,
                    progress: 0,
                    status: 'uploading',
                    error: null,
                    url: URL.createObjectURL(file)
                };
                selectedFiles.push(fileObj);
                simulateUpload(fileObj);
            }
            renderFileList();
        }

        function simulateUpload(fileObj) {
            let progress = 0;
            const isError = Math.random() < 0.05; 
            const errorAt = Math.floor(Math.random() * 80) + 10;

            const interval = setInterval(() => {
                if (isError && progress >= errorAt) {
                    fileObj.status = 'error';
                    fileObj.error = 'Tệp không hợp lệ hoặc bị hỏng';
                    clearInterval(interval);
                    updateFileUI(fileObj);
                    return;
                }

                progress += Math.floor(Math.random() * 30) + 20; 
                if (progress >= 100) {
                    progress = 100;
                    fileObj.status = 'success';
                    clearInterval(interval);
                    checkProcessButton();
                }
                fileObj.progress = progress;
                updateFileUI(fileObj);
            }, 50);
        }

        function removeFile(id) {
            const index = selectedFiles.findIndex(f => f.id === id);
            if (index !== -1) {
                lastDeletedFile = { ...selectedFiles[index], index };
                selectedFiles.splice(index, 1);
                
                const element = document.getElementById(`file-${id}`);
                if (element) {
                    element.style.opacity = '0';
                    element.style.transform = 'scale(0.95) translateX(20px)';
                    element.style.transition = 'all 0.3s ease';
                    setTimeout(() => {
                        element.remove();
                        checkProcessButton();
                    }, 300);
                }
                
                showToast('Đã xóa tệp tin', lastDeletedFile.name, 'undoDelete()');
            }
        }

        function undoDelete() {
            if (lastDeletedFile) {
                selectedFiles.splice(lastDeletedFile.index, 0, lastDeletedFile);
                lastDeletedFile = null;
                renderFileList();
                checkProcessButton();
            }
        }

        function updateFileUI(fileObj) {
            const item = document.getElementById(`file-${fileObj.id}`);
            if (!item) return;

            const statusIcon = item.querySelector('.status-icon');
            const actionIcon = item.querySelector('.action-icon');
            const percentageText = item.querySelector('.percentage-text');

            if (fileObj.status === 'success') {
                statusIcon.innerHTML = `
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-500 fade-in" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                `;
                
                const reviewBtnHtml = `
                    <div class="tooltip tooltip-right w-8 h-8 fade-in">
                        <button onclick="event.stopPropagation(); window.previewFile('${fileObj.id}')" class="w-full h-full flex items-center justify-center text-gray-400 hover:text-black transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><polyline points="10 12 14 12 14 16"/><line x1="14" y1="12" x2="8" y2="18"/>
                            </svg>
                        </button>
                        <span class="tooltiptext">Xem file</span>
                    </div>
                `;

                if (percentageText) {
                    if (fileObj.progress === 100) {
                        // If already finished, show immediately
                        percentageText.classList.add('hidden');
                        actionIcon.innerHTML = reviewBtnHtml;
                    } else {
                        // If just finished, fade out percentage then show
                        percentageText.style.transition = 'opacity 0.4s ease';
                        percentageText.style.opacity = '0';
                        setTimeout(() => {
                            percentageText.classList.add('hidden');
                            actionIcon.innerHTML = reviewBtnHtml;
                        }, 400);
                    }
                }
            } else if (fileObj.status === 'error') {
                statusIcon.innerHTML = `
                    <div class="tooltip tooltip-right fade-in">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-500" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                        </svg>
                        <span class="tooltiptext">${fileObj.error}</span>
                    </div>
                `;
                if (percentageText) percentageText.classList.add('hidden');
                actionIcon.innerHTML = '';
            } else {
                statusIcon.innerHTML = `
                    <svg class="animate-spin h-4 w-4 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                `;
                if (percentageText) {
                    percentageText.classList.remove('hidden');
                    percentageText.style.opacity = '1';
                    percentageText.textContent = `${fileObj.progress}%`;
                }
            }
        }

        function renderFileList() {
            const list = document.getElementById('file-list');
            list.innerHTML = '';
            selectedFiles.forEach(fileObj => {
                const typeInfo = getFileTypeInfo(fileObj.name);
                const div = document.createElement('div');
                div.id = `file-${fileObj.id}`;
                div.className = 'flex items-center justify-between p-2 bg-gray-50 rounded-xl border border-gray-100 transition-all duration-200 group/card hover:border-gray-300 relative z-10 hover:z-20';
                div.innerHTML = `
                    <div class="flex items-center space-x-3 flex-1 min-w-0">
                        <div class="file-type-icon shrink-0 w-8 h-8 ${typeInfo.color} flex items-center justify-center">
                            ${typeInfo.icon}
                        </div>
                        <div class="flex flex-col min-w-0 flex-1">
                            <p class="text-sm font-semibold text-gray-900 truncate">${truncateFilename(fileObj.name)}</p>
                            <p class="text-[10px] text-gray-400 font-mono">${formatBytes(fileObj.size)}</p>
                        </div>
                    </div>
                    <div class="flex items-center shrink-0 space-x-1 ml-auto">
                        <div class="status-icon w-8 h-8 flex items-center justify-center"></div>
                        <div class="relative w-8 h-8 flex items-center justify-center">
                            <span class="percentage-text text-[10px] font-mono text-gray-400">0%</span>
                            <div class="action-icon absolute inset-0 flex items-center justify-center"></div>
                        </div>
                        <div class="tooltip tooltip-right w-8 h-8">
                            <button onclick="removeFile('${fileObj.id}')" class="p-2 text-gray-400 hover:text-red-500 transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
                            </button>
                            <span class="tooltiptext">Xóa file</span>
                        </div>
                    </div>
                `;
                list.appendChild(div);
                updateFileUI(fileObj);
            });
            checkProcessButton();
        }

        function checkProcessButton() {
            const btn = document.getElementById('process-btn');
            const postActions = document.getElementById('post-process-actions');
            
            // Ensure button is visible if results are not shown
            if (postActions.classList.contains('hidden')) {
                if (!isProcessing) {
                    btn.classList.remove('hidden');
                    btn.classList.remove('invisible');
                }
            } else {
                btn.classList.add('hidden');
                return;
            }

            if (isProcessing) return;

            if (currentTool === 'merge') {
                const allSuccess = selectedFiles.length >= 2 && selectedFiles.every(f => f.status === 'success');
                btn.disabled = !allSuccess;
            } else if (currentTool === 'split') {
                const hasFile = selectedFiles.length === 1 && selectedFiles[0].status === 'success';
                btn.disabled = !hasFile;
            } else if (currentTool === 'compress') {
                const hasFile = selectedFiles.length >= 1 && selectedFiles.every(f => f.status === 'success');
                btn.disabled = !hasFile;

                // Update size info
                const totalSize = selectedFiles.reduce((acc, f) => acc + f.size, 0);
                const estimatedSize = totalSize * 0.6; // Estimate 40% reduction
                document.getElementById('original-total-size').textContent = formatBytes(totalSize);
                document.getElementById('estimated-total-size').textContent = '~' + formatBytes(estimatedSize);
            } else if (currentTool === 'lock') {
                const hasFile = selectedFiles.length === 1 && selectedFiles[0].status === 'success';
                const password = document.getElementById('lock-password').value;
                const confirm = document.getElementById('lock-password-confirm').value;
                btn.disabled = !hasFile || !password || password !== confirm;
            } else if (currentTool === 'unlock') {
                const hasFile = selectedFiles.length === 1 && selectedFiles[0].status === 'success';
                const password = document.getElementById('unlock-password').value;
                btn.disabled = !hasFile || !password;
            } else if (currentTool === 'word') {
                const hasFile = selectedFiles.length === 1 && selectedFiles[0].status === 'success';
                btn.disabled = !hasFile;
            } else if (currentTool === 'rotate') {
                const hasFile = selectedFiles.length === 1 && selectedFiles[0].status === 'success';
                btn.disabled = !hasFile;
            }
        }

        function previewFile(id) {
            const fileObj = selectedFiles.find(f => f.id === id);
            if (!fileObj) return;

            const modal = document.getElementById('preview-modal');
            const frame = document.getElementById('preview-frame');
            const title = document.getElementById('preview-filename');

            title.textContent = fileObj.name;
            frame.src = fileObj.url;
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closePreview() {
            const modal = document.getElementById('preview-modal');
            const frame = document.getElementById('preview-frame');
            frame.src = '';
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        async function startProcessing() {
            if (currentTool === 'merge' && selectedFiles.length < 2) return;
            if (currentTool === 'split' && selectedFiles.length !== 1) return;
            
            isProcessing = true;
            const btn = document.getElementById('process-btn');
            const dropzone = document.getElementById('dropzone');
            const fileList = document.getElementById('file-list');
            const splitOptions = document.getElementById('split-options');
            const separator = document.getElementById('modal-separator');
            const modalTitle = document.getElementById('modal-title').textContent;
            
            const modal = document.getElementById('modal');
            const modalContainer = modal.querySelector('.bg-white');
            const workingArea = document.getElementById('modal-working-area');
            
            btn.classList.add('invisible');
            dropzone.classList.add('pointer-events-none');
            // Keep splitOptions and separator visible if it's already visible to maintain modal size
            if (currentTool !== 'split') {
                splitOptions.classList.add('hidden');
                separator.classList.add('hidden');
            }
            const originalDropzoneContent = dropzone.innerHTML;
            
            dropzone.innerHTML = `
                <div class="flex flex-col items-center justify-center space-y-3 py-4">
                    <svg class="animate-spin h-8 w-8 text-black" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    <p class="text-sm font-bold text-black">Đang xử lý...</p>
                </div>
            `;

            try {
                const formData = new FormData();
                let endpoint = '/merge';
                let downloadName = `Pandafun_Merged_${new Date().getTime()}.pdf`;

                if (currentTool === 'merge') {
                    selectedFiles.forEach(f => {
                        formData.append('pdfs', f.file);
                    });
                } else if (currentTool === 'split') {
                    endpoint = '/split';
                    formData.append('pdf', selectedFiles[0].file);
                    const mode = document.querySelector('input[name="split-mode"]:checked').value;
                    formData.append('mode', mode);
                    if (mode === 'range') {
                        formData.append('range', document.getElementById('split-range').value);
                    }
                    downloadName = mode === 'all' ? `Pandafun_Split_${new Date().getTime()}.zip` : `Pandafun_Extracted_${new Date().getTime()}.pdf`;
                } else if (currentTool === 'compress') {
                    endpoint = '/compress';
                    selectedFiles.forEach(f => {
                        formData.append('pdfs', f.file);
                    });
                    downloadName = selectedFiles.length > 1 ? `Pandafun_Compressed_${new Date().getTime()}.zip` : `Pandafun_Compressed_${new Date().getTime()}.pdf`;
                } else if (currentTool === 'lock') {
                    endpoint = '/lock';
                    formData.append('pdf', selectedFiles[0].file);
                    formData.append('password', document.getElementById('lock-password').value);
                    downloadName = `Pandafun_Locked_${new Date().getTime()}.pdf`;
                } else if (currentTool === 'unlock') {
                    endpoint = '/unlock';
                    formData.append('pdf', selectedFiles[0].file);
                    formData.append('password', document.getElementById('unlock-password').value);
                    downloadName = `Pandafun_Unlocked_${new Date().getTime()}.pdf`;
                } else if (currentTool === 'word') {
                    endpoint = '/word';
                    formData.append('pdf', selectedFiles[0].file);
                    downloadName = `Pandafun_Word_${new Date().getTime()}.docx`;
                } else if (currentTool === 'rotate') {
                    endpoint = '/rotate';
                    formData.append('pdf', selectedFiles[0].file);
                    formData.append('rotation', document.getElementById('rotate-angle').value);
                    downloadName = `Pandafun_Rotated_${new Date().getTime()}.pdf`;
                }

                const response = await fetch(endpoint, {
                    method: 'POST',
                    body: formData
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    throw new Error(errorText || 'Xử lý thất bại');
                }

                const blob = await response.blob();
                if (mergedPdfUrl) window.URL.revokeObjectURL(mergedPdfUrl);
                mergedPdfUrl = window.URL.createObjectURL(blob);

                dropzone.innerHTML = `
                    <div class="flex flex-col items-center justify-center space-y-2 py-4">
                        <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center text-green-600">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        </div>
                        <p class="text-sm font-bold text-green-600">${modalTitle} thành công!</p>
                    </div>
                `;
                dropzone.classList.remove('border-dashed');
                dropzone.classList.remove('border-2');
                dropzone.classList.add('border-0');
                dropzone.classList.add('bg-transparent');
                
                fileList.innerHTML = ''; 
                fileList.classList.add('hidden'); 
                
                // Reset layout to single column for success message
                modalContainer.classList.remove('max-w-2xl');
                modalContainer.classList.add('max-w-lg');
                workingArea.classList.remove('md:flex-row');
                document.getElementById('split-options').classList.add('hidden');
                document.getElementById('compress-options').classList.add('hidden');
                document.getElementById('lock-options').classList.add('hidden');
                document.getElementById('modal-separator').classList.add('hidden');

                const downloadBtnText = document.getElementById('download-btn-text');
                if (currentTool === 'merge') {
                    downloadBtnText.textContent = 'Tải xuống tệp đã gộp';
                } else if (currentTool === 'split') {
                    const mode = document.querySelector('input[name="split-mode"]:checked').value;
                    downloadBtnText.textContent = mode === 'all' ? 'Tải xuống tệp ZIP' : 'Tải xuống tệp đã tách';
                } else if (currentTool === 'compress') {
                    downloadBtnText.textContent = selectedFiles.length > 1 ? 'Tải xuống tệp ZIP' : 'Tải xuống tệp đã nén';
                } else if (currentTool === 'lock') {
                    downloadBtnText.textContent = 'Tải xuống tệp đã khóa';
                } else if (currentTool === 'unlock') {
                    downloadBtnText.textContent = 'Tải xuống tệp đã mở khóa';
                } else if (currentTool === 'word') {
                    downloadBtnText.textContent = 'Tải xuống tệp Word (.docx)';
                } else if (currentTool === 'rotate') {
                    downloadBtnText.textContent = 'Tải xuống tệp đã xoay';
                }

                document.getElementById('post-process-actions').classList.remove('hidden');
                btn.classList.add('hidden');
                btn.classList.remove('invisible');
                
                // Store download name for later
                window.currentDownloadName = downloadName;
            } catch (error) {
                console.error(error);
                isProcessing = false;
                btn.classList.remove('hidden');
                btn.classList.remove('invisible');
                dropzone.classList.remove('pointer-events-none');
                if (currentTool === 'split') splitOptions.classList.remove('hidden');
                dropzone.innerHTML = originalDropzoneContent;
                showToast('Lỗi', error.message || 'Đã xảy ra lỗi khi xử lý tệp tin.');
            }
        }

        function previewResult() {
            if (!mergedPdfUrl) return;

            const modal = document.getElementById('preview-modal');
            const frame = document.getElementById('preview-frame');
            const title = document.getElementById('preview-filename');

            const titleMap = {
                'merge': 'Kết quả gộp PDF',
                'split': 'Kết quả tách PDF',
                'compress': 'Kết quả nén PDF',
                'lock': 'Kết quả khóa PDF',
                'rotate': 'Kết quả xoay PDF'
            };
            title.textContent = titleMap[currentTool] || 'Kết quả xử lý';
            
            // ZIP files cannot be previewed in iframe
            const isZip = (currentTool === 'split' && document.querySelector('input[name="split-mode"][value="all"]').checked) || 
                          (currentTool === 'compress' && selectedFiles.length > 1);

            if (isZip) {
                showToast('Thông báo', 'Tệp ZIP không thể xem trước. Vui lòng tải xuống.');
                return;
            }

            if (currentTool === 'lock') {
                showToast('Thông báo', 'Tệp đã khóa có thể yêu cầu mật khẩu để xem trước.');
            }

            frame.src = mergedPdfUrl;
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function downloadResult() {
            if (!mergedPdfUrl) return;
            
            try {
                const a = document.createElement('a');
                a.style.display = 'none';
                a.href = mergedPdfUrl;
                a.download = window.currentDownloadName || `Pandafun_Result_${new Date().getTime()}.pdf`;
                
                document.body.appendChild(a);
                a.click();
                
                setTimeout(() => {
                    document.body.removeChild(a);
                }, 100);
                
                showToast('Thành công', 'Đã tải xuống tệp tin của bạn');
            } catch (error) {
                console.error("Download error:", error);
                showToast('Lỗi', 'Không thể tải xuống tệp tin. Vui lòng thử lại.');
            }
        }

        // Add event listeners for password inputs
        document.addEventListener('DOMContentLoaded', () => {
            const lockPassword = document.getElementById('lock-password');
            const lockPasswordConfirm = document.getElementById('lock-password-confirm');
            if (lockPassword) lockPassword.addEventListener('input', checkProcessButton);
            if (lockPasswordConfirm) lockPasswordConfirm.addEventListener('input', checkProcessButton);
            const unlockPassword = document.getElementById('unlock-password');
            if (unlockPassword) unlockPassword.addEventListener('input', checkProcessButton);
        });
    </script>

    <!-- Toast Container -->
    <div id="toast-container"></div>

    <!-- Footer -->
    <footer class="bg-white border-t border-gray-200 py-12">
        <div class="max-w-7xl mx-auto px-4 text-center text-gray-500">
            <p>&copy; 2026 Pandafun. Tất cả quyền được bảo lưu.</p>
        </div>
    </footer>
</body>
</html>
