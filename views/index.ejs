<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pandafun - Chỉnh sửa PDF dễ dàng</title>
    <script src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .no-scroll { overflow: hidden; }
        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #e5e7eb;
            border-radius: 10px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #d1d5db;
        }
        #file-list {
            scrollbar-gutter: stable;
            padding-top: 40px; /* Space for tooltips of the first items */
            padding-right: 8px;
            overflow-x: hidden;
        }
        .tooltip {
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            z-index: 50;
        }
        .tooltip .tooltiptext {
            visibility: hidden;
            width: max-content;
            background-color: #000000;
            color: white;
            text-align: center;
            border-radius: 6px;
            padding: 6px 12px;
            position: absolute;
            z-index: 10000;
            bottom: 125%;
            left: 50%;
            transform: translateX(-50%) translateY(8px);
            opacity: 0;
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            font-size: 11px;
            font-weight: 600;
            pointer-events: none;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
            white-space: nowrap;
        }
        /* Tooltip for elements on the right side to avoid clipping */
        .tooltip-right .tooltiptext {
            left: auto !important;
            right: 0 !important;
            transform: translateY(8px) !important;
        }
        .tooltip-right .tooltiptext::after {
            left: auto !important;
            right: 10px !important;
            margin-left: 0 !important;
        }
        .tooltip .tooltiptext::after {
            content: "";
            position: absolute;
            top: 100%;
            left: 50%;
            margin-left: -5px;
            border-width: 5px;
            border-style: solid;
            border-color: #000000 transparent transparent transparent;
        }
        .tooltip:hover .tooltiptext {
            visibility: visible;
            opacity: 1;
            transform: translateX(-50%) translateY(0);
        }
        .tooltip-right:hover .tooltiptext {
            transform: translateY(0) !important;
        }
        #toast-container {
            position: fixed;
            bottom: 32px;
            right: 32px;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            gap: 12px;
            align-items: flex-end;
            pointer-events: none;
        }
        .toast {
            background: #f3f4f6;
            border: 1px solid #ef4444;
            padding: 12px 16px;
            border-radius: 12px;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            display: flex;
            flex-direction: column;
            width: 340px;
            pointer-events: auto;
            animation: toastSlideIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
            position: relative;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }
        /* Stacking logic: only if more than 3, stack at the top */
        .toast:nth-last-child(n+4) {
            margin-bottom: -60px;
            transform: scale(0.94) translateY(10px);
            opacity: 0.5;
            filter: blur(1px);
            z-index: -1;
            pointer-events: none;
        }
        #toast-container:hover .toast {
            margin-bottom: 0;
            transform: scale(1) translateY(0);
            opacity: 1;
            filter: none;
            z-index: 1;
            pointer-events: auto;
        }
        @keyframes toastSlideIn {
            from { transform: translateX(100%) translateY(20px); opacity: 0; }
            to { transform: translateX(0) translateY(0); opacity: 1; }
        }
        .toast-exit {
            animation: toastSlideOut 0.3s ease-in forwards;
        }
        @keyframes toastSlideOut {
            from { transform: translateX(0); opacity: 1; }
            to { transform: translateX(100%); opacity: 0; }
        }
        .toast-filename {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            word-break: break-all;
            line-height: 1.4;
            color: #4b5563;
            font-size: 13px;
        }
        .toast-countdown {
            position: absolute;
            bottom: 0;
            left: 0;
            height: 2px;
            background: #ef4444;
            width: 100%;
            transform-origin: left;
            border-radius: 0 0 12px 12px;
        }
        @keyframes countdown {
            from { transform: scaleX(1); }
            to { transform: scaleX(0); }
        }
        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        .animate-spin-slow {
            animation: spin 2s linear infinite;
        }
        .fade-in {
            animation: fadeIn 0.4s ease forwards;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: scale(0.9); }
            to { opacity: 1; transform: scale(1); }
        }
    </style>
</head>
<body class="bg-gray-50">
    <!-- Toolbar -->
    <nav class="bg-white border-b border-gray-200 px-4 py-3 flex items-center justify-between sticky top-0 z-50">
        <div class="flex items-center space-x-2">
            <div class="w-10 h-10 bg-black rounded-full flex items-center justify-center text-white text-2xl">🐼</div>
            <span class="text-2xl font-bold tracking-tight">Pandafun</span>
        </div>
        
        <div class="hidden md:flex items-center space-x-6">
            <button class="text-gray-600 hover:text-black font-medium">Tìm kiếm</button>
            
            <!-- Dropdown Công cụ -->
            <div class="relative group">
                <button class="text-gray-600 group-hover:text-black font-medium flex items-center space-x-1 py-2">
                    <span>Công cụ</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down transition-transform group-hover:rotate-180"><path d="m6 9 6 6 6-6"/></svg>
                </button>
                
                <!-- Dropdown Menu -->
                <div class="absolute left-0 top-full pt-2 w-64 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-[110]">
                    <div class="bg-white border border-gray-100 rounded-xl shadow-xl overflow-hidden p-2">
                        <div class="grid grid-cols-1 gap-1">
                            <% tools.forEach(tool => { %>
                                <a href="#" onclick="openModal('<%= tool.id %>')" class="flex items-center space-x-3 p-2 rounded-lg hover:bg-gray-50 transition-colors group/item">
                                    <div class="bg-gray-50 text-black <%= tool.hoverBg %> <%= tool.hoverText %> w-8 h-8 rounded-md flex items-center justify-center shrink-0 transition-colors">
                                        <div class="scale-75"><%- tool.icon %></div>
                                    </div>
                                    <span class="text-sm font-semibold text-gray-700 group-hover/item:text-black"><%= tool.title %></span>
                                </a>
                            <% }) %>
                        </div>
                    </div>
                </div>
            </div>

            <button class="text-gray-600 hover:text-black font-medium">Giá cả</button>
            <button class="bg-black text-white px-5 py-2 rounded-lg font-semibold hover:bg-gray-800 transition-colors">Đăng nhập</button>
        </div>
        
        <!-- Mobile Menu Icon (Placeholder) -->
        <div class="md:hidden">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
            </svg>
        </div>
    </nav>

    <!-- Hero Section -->
    <header class="max-w-7xl mx-auto px-4 py-12 text-center">
        <h1 class="text-4xl font-extrabold text-gray-900 mb-4 tracking-tight">Mọi công cụ PDF bạn cần</h1>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">Pandafun giúp bạn gộp, tách, nén và chuyển đổi PDF một cách nhanh chóng và hoàn toàn miễn phí.</p>
    </header>

    <!-- Tools Grid -->
    <main class="max-w-7xl mx-auto px-4 pb-24">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <% tools.forEach(tool => { %>
                <div onclick="openModal('<%= tool.id %>')" class="bg-white p-8 rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-all cursor-pointer group">
                    <div class="flex flex-col space-y-4">
                        <div class="flex items-center space-x-4">
                            <div class="<%= tool.color %> <%= tool.textColor %> w-12 h-12 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform shrink-0">
                                <%- tool.icon %>
                            </div>
                            <h3 class="text-xl font-bold text-gray-900"><%= tool.title %></h3>
                        </div>
                        <p class="text-gray-500 leading-relaxed"><%= tool.subtitle %></p>
                    </div>
                </div>
            <% }) %>
        </div>
    </main>

    <!-- Main Modal -->
    <div id="modal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-[100] p-4">
        <div class="bg-white w-full max-w-lg h-[480px] rounded-2xl p-4 relative shadow-2xl flex flex-col overflow-hidden transition-all duration-300">
            <button onclick="closeModal()" class="absolute top-4 right-4 text-gray-400 hover:text-black transition-colors z-10">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
            
            <h2 id="modal-title" class="text-base font-bold mb-2 shrink-0">Gộp PDF</h2>
            
            <div id="modal-content" class="flex-1 flex flex-col min-h-0 space-y-2">
                <div id="modal-working-area" class="flex-1 flex flex-col min-h-0 gap-3">
                    <div id="files-container" class="flex-1 flex flex-col min-h-0 space-y-3">
                        <!-- Dropzone (Smaller) -->
                        <div id="dropzone" class="border-2 border-dashed border-gray-200 rounded-xl p-3 text-center hover:border-black transition-all cursor-pointer group bg-gray-50/50 shrink-0" onclick="document.getElementById('file-input').click()">
                            <div class="w-6 h-6 bg-white rounded-full flex items-center justify-center mx-auto mb-1 shadow-sm group-hover:scale-110 transition-transform">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-gray-400 group-hover:text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                                </svg>
                            </div>
                            <p class="text-xs text-gray-600 font-medium">Kéo thả hoặc nhấn để chọn tệp PDF</p>
                            <input id="file-input" type="file" name="pdfs" multiple accept="application/pdf" class="hidden" onchange="handleFiles(this.files)">
                        </div>

                        <!-- File List Container (Scrollable) -->
                        <div id="file-list" class="flex-1 overflow-y-auto space-y-2 pr-1 custom-scrollbar min-h-0">
                            <!-- File items will be injected here -->
                        </div>
                    </div>

                    <!-- Vertical Separator (Hidden by default) -->
                    <div id="modal-separator" class="hidden md:block w-px bg-gray-100 shrink-0"></div>

                    <!-- Split Options (Hidden by default) -->
                    <div id="split-options" class="hidden w-full md:w-56 space-y-2 shrink-0 flex flex-col">
                        <div class="space-y-2">
                            <!-- Option 1: Split All -->
                            <div class="border-2 border-gray-100 rounded-2xl p-2 transition-all hover:border-gray-300 has-[:checked]:border-black has-[:checked]:ring-4 has-[:checked]:ring-black/5">
                                <label class="relative flex items-center cursor-pointer group">
                                    <input type="radio" name="split-mode" value="all" checked class="hidden peer">
                                    <div class="w-3.5 h-3.5 border-2 border-gray-300 rounded-full mr-2 peer-checked:border-black peer-checked:border-[4px] transition-all"></div>
                                    <div class="flex flex-col">
                                        <span class="text-xs font-bold text-gray-800">Tất cả các trang</span>
                                        <span class="text-[10px] text-gray-500">Mỗi trang thành một file riêng</span>
                                    </div>
                                </label>
                            </div>
                            
                            <!-- Option 2: Split Range (Grouped with Input) -->
                            <div class="border-2 border-gray-100 rounded-2xl p-2 space-y-2 transition-all hover:border-gray-300 has-[:checked]:border-black has-[:checked]:ring-4 has-[:checked]:ring-black/5 focus-within:border-black focus-within:ring-4 focus-within:ring-black/5">
                                <label class="relative flex items-center cursor-pointer group">
                                    <input type="radio" name="split-mode" value="range" class="hidden peer">
                                    <div class="w-3.5 h-3.5 border-2 border-gray-300 rounded-full mr-2 peer-checked:border-black peer-checked:border-[4px] transition-all"></div>
                                    <div class="flex flex-col">
                                        <span class="text-xs font-bold text-gray-800">Khoảng trang</span>
                                        <span class="text-[10px] text-gray-500">Trích xuất các trang cụ thể</span>
                                    </div>
                                </label>

                                <div id="range-input-container" class="pl-5">
                                    <input type="text" id="split-range" placeholder="Ví dụ: 1-3, 5" 
                                        class="w-full px-2 py-1.5 text-xs border border-gray-200 rounded-lg focus:outline-none transition-all bg-gray-50 focus:bg-white focus:border-gray-300"
                                        onfocus="document.querySelector('input[name=\'split-mode\'][value=\'range\']').checked = true">
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Compress Options (Hidden by default) -->
                    <div id="compress-options" class="hidden w-full md:w-56 space-y-3 shrink-0 flex flex-col">
                        <div class="p-4 bg-gray-50 rounded-2xl border-2 border-gray-100 space-y-3">
                            <div class="space-y-2">
                                <div class="flex justify-between items-center">
                                    <span class="text-[10px] text-gray-500 uppercase tracking-wider">Dung lượng gốc</span>
                                    <span id="original-total-size" class="text-xs font-mono font-bold text-gray-900">0 KB</span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="text-[10px] text-gray-500 uppercase tracking-wider">Ước tính sau nén</span>
                                    <span id="estimated-total-size" class="text-xs font-mono font-bold text-green-600">~0 KB</span>
                                </div>
                                <div class="h-1 w-full bg-gray-200 rounded-full overflow-hidden mt-1">
                                    <div class="h-full bg-green-500 w-[40%]"></div>
                                </div>
                                <p class="text-[9px] text-gray-400 italic text-left leading-tight">
                                    * Mức nén thực tế phụ thuộc vào nội dung tệp tin.
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Lock Options (Hidden by default) -->
                    <div id="lock-options" class="hidden w-full md:w-56 space-y-3 shrink-0 flex flex-col">
                        <div class="p-4 bg-gray-50 rounded-2xl border-2 border-gray-100 space-y-4">
                            <div class="space-y-2">
                                <label class="text-xs font-bold text-gray-800">Mật khẩu bảo vệ</label>
                                <div class="relative">
                                    <input type="password" id="lock-password" placeholder="Nhập mật khẩu..." 
                                        class="w-full px-3 py-2 text-sm border border-gray-200 rounded-xl focus:outline-none transition-all bg-white focus:border-black focus:ring-4 focus:ring-black/5">
                                    <button type="button" onclick="togglePassword('lock-password')" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-black">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-eye"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                                    </button>
                                </div>
                            </div>
                            <div class="space-y-2">
                                <label class="text-xs font-bold text-gray-800">Xác nhận mật khẩu</label>
                                <div class="relative">
                                    <input type="password" id="lock-password-confirm" placeholder="Nhập lại mật khẩu..." 
                                        class="w-full px-3 py-2 text-sm border border-gray-200 rounded-xl focus:outline-none transition-all bg-white focus:border-black focus:ring-4 focus:ring-black/5">
                                    <button type="button" onclick="togglePassword('lock-password-confirm')" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-black">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-eye"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                                    </button>
                                </div>
                            </div>
                            <p class="text-[9px] text-gray-400 italic text-left leading-tight">
                                * Ghi nhớ mật khẩu của bạn. Chúng tôi không thể khôi phục nó nếu bạn quên.
                            </p>
                        </div>
                    </div>

                    <!-- Unlock Options (Hidden by default) -->
                    <div id="unlock-options" class="hidden w-full md:w-56 space-y-3 shrink-0 flex flex-col">
                        <div class="p-4 bg-gray-50 rounded-2xl border-2 border-gray-100 space-y-4">
                            <div class="space-y-2">
                                <label class="text-xs font-bold text-gray-800">Mật khẩu hiện tại</label>
                                <div class="relative">
                                    <input type="password" id="unlock-password" placeholder="Nhập mật khẩu để mở..." 
                                        class="w-full px-3 py-2 text-sm border border-gray-200 rounded-xl focus:outline-none transition-all bg-white focus:border-black focus:ring-4 focus:ring-black/5">
                                    <button type="button" onclick="togglePassword('unlock-password')" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-black">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-eye"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                                    </button>
                                </div>
                            </div>
                            <p class="text-[9px] text-gray-400 italic text-left leading-tight">
                                * Nhập mật khẩu chính xác để gỡ bỏ lớp bảo vệ khỏi tệp PDF.
                            </p>
                        </div>
                    </div>

                    <!-- Word Options (Hidden by default) -->
                    <div id="word-options" class="hidden w-full md:w-56 space-y-3 shrink-0 flex flex-col">
                        <div class="p-4 bg-gray-50 rounded-2xl border-2 border-gray-100 space-y-3">
                            <div class="flex items-center space-x-2 text-blue-600">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
                                <span class="text-xs font-bold uppercase tracking-wider">PDF sang Word</span>
                            </div>
                            <p class="text-[10px] text-gray-500 leading-relaxed">
                                Chuyển đổi nội dung văn bản từ PDF sang định dạng Word (.docx) có thể chỉnh sửa.
                            </p>
                        </div>
                    </div>

                    <!-- Rotate Options (Hidden by default) -->
                    <div id="rotate-options" class="hidden w-full md:w-56 space-y-3 shrink-0 flex flex-col">
                        <div class="p-4 bg-gray-50 rounded-2xl border-2 border-gray-100 space-y-4">
                            <div class="space-y-2">
                                <label class="text-xs font-bold text-gray-800">Góc xoay</label>
                                <select id="rotate-angle" class="w-full px-3 py-2 text-sm border border-gray-200 rounded-xl focus:outline-none transition-all bg-white focus:border-black focus:ring-4 focus:ring-black/5">
                                    <option value="90">90° Phải</option>
                                    <option value="180">180°</option>
                                    <option value="270">90° Trái</option>
                                </select>
                            </div>
                            <p class="text-[9px] text-gray-400 italic text-left leading-tight">
                                * Toàn bộ các trang trong tệp PDF sẽ được xoay theo góc đã chọn.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Action Button Container -->
                <div id="action-container" class="pt-3 border-t shrink-0">
                    <button id="process-btn" disabled onclick="startProcessing()" class="w-full bg-black text-white py-2.5 rounded-xl font-bold hover:bg-gray-800 transition-all disabled:bg-gray-100 disabled:text-gray-400 disabled:cursor-not-allowed shadow-lg shadow-black/5 text-sm">Xử lý</button>
                    
                    <!-- Post-processing buttons (Hidden by default) -->
                    <div id="post-process-actions" class="hidden flex flex-col space-y-2 w-full">
                        <div class="grid grid-cols-2 gap-2">
                            <button onclick="resetModal()" class="flex items-center justify-center space-x-2 bg-gray-100 text-gray-700 py-2.5 rounded-xl font-bold hover:bg-gray-200 transition-all text-sm">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
                                <span>Thực hiện mới</span>
                            </button>
                            <button onclick="previewResult()" class="flex items-center justify-center space-x-2 bg-gray-100 text-gray-700 py-2.5 rounded-xl font-bold hover:bg-gray-200 transition-all text-sm">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                                <span>Xem kết quả</span>
                            </button>
                        </div>
                        <button onclick="downloadResult()" class="w-full flex items-center justify-center space-x-2 bg-black text-white py-2.5 rounded-xl font-bold hover:bg-gray-800 transition-all shadow-lg shadow-black/10 text-sm">
