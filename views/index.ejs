                modalContainer.classList.remove('max-w-lg');
                modalContainer.classList.add('max-w-2xl');
                workingArea.classList.add('md:flex-row');
            } else if (toolId === 'unlock') {
                modalTitle.textContent = 'Mở khóa PDF';
                fileInput.multiple = false;
                unlockOptions.classList.remove('hidden');
