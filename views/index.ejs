        let mergedPdfUrl = null;

        function showToast(message, filename, undoAction = null) {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = 'toast';
            
            let undoBtn = '';
            if (undoAction) {
                undoBtn = `
                    <div class="tooltip tooltip-right w-8 h-8">
                        <button onclick="this.closest('.toast').remove(); ${undoAction}" class="p-1.5 text-gray-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-all active:scale-90">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
                        </button>
                        <span class="tooltiptext">Hoàn tác</span>
